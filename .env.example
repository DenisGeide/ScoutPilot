# Режим запуска: development, test или production.
SCOUT_PILOT_ENV=development

# Пользовательский CLI остается русским; внутренние structured logs остаются английскими.
SCOUT_PILOT_LOG_LEVEL=INFO

# Настройки браузера. Видимый режим удобен для интервью-демо.
SCOUT_PILOT_BROWSER_PROFILE_DIR=.browser-profiles/default
SCOUT_PILOT_BROWSER_HEADLESS=false
SCOUT_PILOT_BROWSER_DEFAULT_TIMEOUT_MS=10000
SCOUT_PILOT_BROWSER_NAVIGATION_TIMEOUT_MS=15000
SCOUT_PILOT_BROWSER_SCREENSHOTS_DIR=reports/tmp/screenshots

# Лимиты семантического наблюдения. Они защищают размер LLM-контекста.
SCOUT_PILOT_OBSERVATION_MAX_SECTIONS=12
SCOUT_PILOT_OBSERVATION_MAX_INTERACTIVE_ELEMENTS=40
SCOUT_PILOT_OBSERVATION_MAX_FORM_FIELDS=25
SCOUT_PILOT_OBSERVATION_MAX_DIALOGS=5
SCOUT_PILOT_OBSERVATION_MAX_SECTION_CHARS=700
SCOUT_PILOT_OBSERVATION_MAX_TOTAL_CHARS=6000

# Локальные артефакты. Реальные профили, диагностику и приватные отчеты не коммитить.
SCOUT_PILOT_REPORTS_DIR=reports

# Настройки LLM-провайдера. Реальные ключи хранить только в локальном .env.
SCOUT_PILOT_LLM_PROVIDER=openai
SCOUT_PILOT_LLM_MODEL=gpt-4.1-mini
SCOUT_PILOT_LLM_TIMEOUT_SECONDS=30
SCOUT_PILOT_LLM_MAX_OUTPUT_TOKENS=1200
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Безопасность и бюджет контекста.
SCOUT_PILOT_REQUIRE_CONFIRMATION=true
SCOUT_PILOT_MAX_CONTEXT_TOKENS=12000
