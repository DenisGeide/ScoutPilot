# Runtime mode: development, test or production.
SCOUT_PILOT_ENV=development

# User-facing CLI remains Russian; internal structured logs remain English.
SCOUT_PILOT_LOG_LEVEL=INFO

# Browser defaults. Headed mode is the default for interview demos.
SCOUT_PILOT_BROWSER_PROFILE_DIR=.browser-profiles/default
SCOUT_PILOT_BROWSER_HEADLESS=false
SCOUT_PILOT_BROWSER_DEFAULT_TIMEOUT_MS=10000
SCOUT_PILOT_BROWSER_NAVIGATION_TIMEOUT_MS=15000
SCOUT_PILOT_BROWSER_SCREENSHOTS_DIR=reports/tmp/screenshots

# Local artifacts. Keep real profiles, diagnostics and private reports out of Git.
SCOUT_PILOT_REPORTS_DIR=reports

# Provider configuration for later stages. Do not commit real keys.
SCOUT_PILOT_LLM_PROVIDER=openai
SCOUT_PILOT_LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Safety and context defaults.
SCOUT_PILOT_REQUIRE_CONFIRMATION=true
SCOUT_PILOT_MAX_CONTEXT_TOKENS=12000
